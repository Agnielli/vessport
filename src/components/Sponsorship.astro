---
// Sponsorship section for Eloy Trigo
---

<section id="embajador" class="py-24 bg-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row items-center gap-16">
      <!-- Image Column: Mosaic Gallery -->
      <div class="w-full lg:w-1/2 relative group">
        <div class="grid grid-cols-3 gap-3 h-[600px] md:h-[700px]">
          <!-- Imagen Principal: Meta (Éxito) - Ocupa 2x2 -->
          <div
            class="col-span-2 row-span-2 rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 group/item cursor-zoom-in"
            onclick="openLightbox(this)"
          >
            <img
              src="/images/EloyTrigo/WhatsApp Image 2026-04-20 at 22.49.19 (2).jpeg"
              alt="Eloy Trigo en línea de meta"
              class="w-full h-full object-cover transform transition-transform duration-700 group-hover/item:scale-110"
            />
          </div>

          <!-- Imagen 2: Montaña (Épica) - Ocupa 1x1 -->
          <div
            class="col-span-1 row-span-1 rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 group/item cursor-zoom-in"
            onclick="openLightbox(this)"
          >
            <img
              src="/images/EloyTrigo/WhatsApp Image 2026-04-20 at 22.49.19.jpeg"
              alt="Eloy Trigo en la montaña"
              class="w-full h-full object-cover transform transition-transform duration-700 group-hover/item:scale-110"
            />
          </div>

          <!-- Imagen 3: Trofeo (Reconocimiento) - Ocupa 1x1 -->
          <div
            class="col-span-1 row-span-1 rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 group/item cursor-zoom-in"
            onclick="openLightbox(this)"
          >
            <img
              src="/images/EloyTrigo/motion_photo_503630983549248566.jpg"
              alt="Eloy Trigo con trofeo"
              class="w-full h-full object-cover transform transition-transform duration-700 group-hover/item:scale-110"
            />
          </div>

          <!-- Imagen 4: Primer Plano (Humano) - Ocupa 1x1 -->
          <div
            class="col-span-1 row-span-1 rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 group/item cursor-zoom-in"
            onclick="openLightbox(this)"
          >
            <img
              src="/images/EloyTrigo/WhatsApp Image 2026-04-20 at 22.49.19 (1).jpeg"
              alt="Primer plano Eloy Trigo"
              class="w-full h-full object-cover transform transition-transform duration-700 group-hover/item:scale-110"
            />
          </div>

          <!-- Imagen 6: Podio (Equipo) - Ocupa 1x1 -->
          <div
            class="col-span-1 row-span-1 rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 group/item cursor-zoom-in"
            onclick="openLightbox(this)"
          >
            <img
              src="/images/EloyTrigo/WhatsApp Image 2026-04-20 at 22.49.19 (3).jpeg"
              alt="Podio Eloy Trigo"
              class="w-full h-full object-cover transform transition-transform duration-700 group-hover/item:scale-110"
            />
          </div>
          <!-- Imagen 5: Carrera Césped (Agilidad) - Ocupa 1x1 -->
          <div
            class="col-span-1 row-span-1 rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 group/item cursor-zoom-in"
            onclick="openLightbox(this)"
          >
            <img
              src="/images/EloyTrigo/WhatsApp Image 2026-04-21 at 22.13.01.jpeg"
              alt="Eloy Trigo corriendo"
              class="w-full h-full object-cover transform transition-transform duration-700 group-hover/item:scale-110"
            />
          </div>
        </div>

        <!-- Stats Badge (Posicionado sobre el mosaico) -->
        <div
          class="absolute -bottom-6 -right-6 bg-white p-5 rounded-2xl shadow-2xl z-20 border border-gray-100 hidden md:block animate-bounce-subtle"
        >
          <div class="flex items-center gap-4">
            <div
              class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center text-primary shadow-inner"
            >
              <svg
                class="w-7 h-7"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg
              >
            </div>
            <div>
              <p
                class="text-[10px] text-gray-400 uppercase tracking-[0.2em] font-black"
              >
                Performance
              </p>
              <p class="text-lg font-black text-gray-900 tracking-tight">
                ELITE ATHLETE
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Text Column -->
      <div class="w-full lg:w-1/2 space-y-8">
        <div>
          <span
            class="inline-block px-4 py-1.5 bg-primary/10 text-primary text-sm font-bold rounded-full mb-6 uppercase tracking-widest"
          >
            Athlete Sponsorship
          </span>
          <h2
            class="text-4xl md:text-5xl font-light text-gray-900 mb-6 tracking-tight leading-tight"
          >
            Eloy Trigo: <br />
            <span class="font-bold text-primary"
              >El conquistador del desierto</span
            >
          </h2>
          <div class="w-20 h-1.5 bg-primary rounded-full mb-8"></div>
        </div>

        <div class="prose prose-lg text-gray-600 font-light leading-relaxed">
          <p>
            En <strong>Ves Sport</strong>, nos enorgullece patrocinar a <strong
              >Eloy Trigo Calzado</strong
            >, corredor del club <strong>CP Mijas Trail</strong> y uno de los nombres
            propios del ultrafondo en España. Eloy encarna los valores de resistencia
            extrema y superación en los terrenos más técnicos del país.
          </p>

          <!-- Hito Principal Highlight Box -->
          <div
            class="my-8 p-6 bg-primary/5 rounded-2xl border-l-4 border-primary"
          >
            <h4 class="text-xl font-bold text-gray-900 mb-2">
              🏆 Campeón de La Desértica 2024
            </h4>
            <p class="text-base">
              Dominó los <strong>72 km</strong> de Almería con un tiempo espectacular
              de <strong>05:55:08</strong>, coronándose vencedor absoluto en una
              de las pruebas más duras y áridas de España.
            </p>
          </div>

          <p>
            Su éxito más reciente con nuestra equipación incluye una
            espectacular <strong>6ª posición</strong> en la <strong
              >Ultra Sierra Nevada 2026</strong
            >, firmando su mejor actuación personal ante un pelotón de 250
            corredores de élite mundial.
          </p>
        </div>

        <!-- Palmarés Grid -->
        <div class="space-y-4 pt-6">
          <h4 class="text-sm font-bold text-gray-400 uppercase tracking-widest">
            Resultados Destacados
          </h4>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div
              class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl border border-gray-100"
            >
              <span class="text-primary font-bold">2026</span>
              <span class="text-sm text-gray-700 leading-tight"
                ><strong>6ª posición</strong> Ultra Sierra Nevada</span
              >
            </div>
            <div
              class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl border border-gray-100"
            >
              <span class="text-primary font-bold">2025</span>
              <span class="text-sm text-gray-700 leading-tight"
                ><strong>3º Senior</strong> 101 KM de la Legión (Ronda)</span
              >
            </div>
            <div
              class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl border border-gray-100"
            >
              <span class="text-primary font-bold">2024</span>
              <span class="text-sm text-gray-700 leading-tight"
                ><strong>1º General</strong> La Desértica (Almería)</span
              >
            </div>
            <div
              class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl border border-gray-100"
            >
              <span class="text-primary font-bold">2024</span>
              <span class="text-sm text-gray-700 leading-tight"
                ><strong>Top 12</strong> 101 KM de Ronda (10:16h)</span
              >
            </div>
          </div>
        </div>

        <div class="pt-8">
          <a
            href="#contacto"
            class="inline-flex items-center text-primary font-bold hover:gap-4 transition-all group"
          >
            Únete al equipo Ves Sport
            <svg
              class="w-5 h-5 ml-2 transition-transform group-hover:translate-x-1"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
            >
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Lightbox Modal -->
<div
  id="lightbox"
  class="fixed inset-0 z-[100] hidden bg-black/95 backdrop-blur-md items-center justify-center p-4"
  onclick="closeLightbox(event)"
>
  <!-- Botones de Navegación -->
  <button
    class="absolute left-4 top-1/2 -translate-y-1/2 text-white/50 hover:text-white transition-colors z-[110] p-2 bg-black/20 rounded-full hover:bg-black/40"
    onclick="prevImage(event)"
    aria-label="Anterior"
  >
    <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"
      ><path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M15 19l-7-7 7-7"></path></svg
    >
  </button>

  <button
    class="absolute right-4 top-1/2 -translate-y-1/2 text-white/50 hover:text-white transition-colors z-[110] p-2 bg-black/20 rounded-full hover:bg-black/40"
    onclick="nextImage(event)"
    aria-label="Siguiente"
  >
    <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"
      ><path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M9 5l7 7-7 7"></path></svg
    >
  </button>

  <div
    class="relative max-w-full max-h-full flex items-center justify-center animate-fade-in"
    onclick="event.stopPropagation()"
  >
    <img
      id="lightbox-img"
      src=""
      alt="Ampliada"
      class="max-w-[95vw] max-h-[90vh] w-auto h-auto object-contain rounded-lg shadow-2xl transition-all duration-300"
    />

    <button
      class="absolute -top-12 right-0 text-white hover:text-primary transition-colors p-2"
      onclick="closeLightbox(event)"
    >
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path></svg
      >
    </button>

    <!-- Indicador de imagen -->
    <div
      id="lightbox-counter"
      class="absolute -bottom-10 left-1/2 -translate-x-1/2 text-white/60 text-sm font-light tracking-widest uppercase"
    >
      1 / 6
    </div>
  </div>
</div>

<script is:inline>
  let currentImgIndex = 0;
  let galleryImages = [];

  function initGallery() {
    const galleryContainer = document.querySelector('#embajador .grid');
    if (galleryContainer) {
      galleryImages = Array.from(galleryContainer.querySelectorAll('img')).map(
        (img) => ({
          src: img.src,
          alt: img.alt,
        }),
      );
    }
  }

  // Inicializar al cargar
  initGallery();

  function openLightbox(element) {
    const clickedImg = element.querySelector('img');
    currentImgIndex = galleryImages.findIndex(
      (img) => img.src === clickedImg.src,
    );
    updateLightbox();

    const lightbox = document.getElementById('lightbox');
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function updateLightbox() {
    const lightboxImg = document.getElementById('lightbox-img');
    const lightboxCounter = document.getElementById('lightbox-counter');

    if (galleryImages[currentImgIndex]) {
      // Fade out effect
      lightboxImg.style.opacity = '0';

      setTimeout(() => {
        lightboxImg.src = galleryImages[currentImgIndex].src;
        lightboxImg.alt = galleryImages[currentImgIndex].alt;
        lightboxCounter.textContent = `${currentImgIndex + 1} / ${galleryImages.length}`;
        lightboxImg.style.opacity = '1';
      }, 150);
    }
  }

  function nextImage(e) {
    if (e) e.stopPropagation();
    currentImgIndex = (currentImgIndex + 1) % galleryImages.length;
    updateLightbox();
  }

  function prevImage(e) {
    if (e) e.stopPropagation();
    currentImgIndex =
      (currentImgIndex - 1 + galleryImages.length) % galleryImages.length;
    updateLightbox();
  }

  function closeLightbox(e) {
    if (e) e.stopPropagation();
    const lightbox = document.getElementById('lightbox');
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = 'auto';
  }

  // Soporte de Teclado
  document.addEventListener('keydown', (e) => {
    const lightbox = document.getElementById('lightbox');
    if (lightbox.classList.contains('hidden')) return;

    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowRight') nextImage();
    if (e.key === 'ArrowLeft') prevImage();
  });
</script>
