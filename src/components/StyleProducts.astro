<!-- JavaScript for Enhanced Interactions -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    
    // --- Tabs Logic ---
    const tabs = document.querySelectorAll('.category-tab');
    const contents = document.querySelectorAll('.category-content');
    
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        // Remove active state from all tabs
        tabs.forEach(t => {
          t.classList.remove('bg-primary', 'text-white', 'shadow-md');
          t.classList.add('bg-white', 'text-gray-600', 'hover:bg-gray-100', 'border', 'border-gray-200');
        });
        
        // Add active state to clicked tab
        tab.classList.remove('bg-white', 'text-gray-600', 'hover:bg-gray-100', 'border', 'border-gray-200');
        tab.classList.add('bg-primary', 'text-white', 'shadow-md');
        
        // Hide all contents
        contents.forEach(content => {
          content.classList.remove('opacity-100', 'relative', 'z-10');
          content.classList.add('opacity-0', 'absolute', 'pointer-events-none');
        });
        
        // Show target content
        const targetId = tab.getAttribute('data-target');
        const targetContent = document.getElementById(targetId);
        if(targetContent) {
          targetContent.classList.remove('opacity-0', 'absolute', 'pointer-events-none');
          targetContent.classList.add('opacity-100', 'relative', 'z-10');
          
          // Re-trigger intersection observer for newly visible cards
          const newCards = targetContent.querySelectorAll('.product-card');
          newCards.forEach((card, index) => {
            card.style.transition = 'none';
            card.style.opacity = '0';
            card.style.transform = 'translateY(30px)';
            
            // Force reflow
            void card.offsetWidth;
            
            card.style.transition = `opacity 0.6s ease-out ${index * 0.1}s, transform 0.6s ease-out ${index * 0.1}s`;
            card.style.opacity = '1';
            card.style.transform = 'translateY(0)';
          });
        }
      });
    });

    // --- Cards Flip Logic (Mobile) ---
    const productCards = document.querySelectorAll('.product-card');
    
    productCards.forEach(card => {
      // Click to toggle between front and back view
      card.addEventListener('click', function(e) {
        // Don't trigger if clicking on the button or link
        if (e.target.closest('a') || e.target.closest('button')) return;
        card.classList.toggle('flipped');
      });
      
      // Reset on mouse leave
      card.addEventListener('mouseleave', function() {
        card.classList.remove('flipped');
      });
    });
    
    // --- Intersection Observer for scroll animations ---
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
        }
      });
    }, observerOptions);
    
    // Observe initially visible product cards
    const initialCards = document.getElementById('category-0').querySelectorAll('.product-card');
    initialCards.forEach((card, index) => {
      card.style.opacity = '0';
      card.style.transform = 'translateY(30px)';
      card.style.transition = `opacity 0.6s ease-out ${index * 0.1}s, transform 0.6s ease-out ${index * 0.1}s`;
      observer.observe(card);
    });
  });
</script>