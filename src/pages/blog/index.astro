---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';

// Obtener todas las entradas del blog y ordenarlas por fecha (más reciente primero)
const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

// El post destacado es el primero que tenga featured: true, o el más reciente si ninguno lo tiene
const featuredPost = sortedPosts.length > 0 ? (sortedPosts.find(p => p.data.featured) || sortedPosts[0]) : null;
const otherPosts = featuredPost ? sortedPosts.filter(p => p.id !== featuredPost.id) : [];

// Función para formatear la fecha en español
const formatDate = (dateString) => {
  const options = { year: 'numeric', month: 'long', day: 'numeric' };
  return new Date(dateString).toLocaleDateString('es-ES', options);
};
---

<Layout title="Blog | Ves Sport - Noticias y Actualidad Deportiva">
  <Header />
  
  <main class="pt-32 pb-24 bg-white">
    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-20 text-center">
      <h1 class="text-5xl md:text-7xl font-light text-gray-900 mb-8 tracking-tighter">
        Nuestro <span class="text-primary italic font-serif">Blog</span>
      </h1>
      <p class="text-xl text-gray-500 font-light max-w-3xl mx-auto leading-relaxed">
        Compartimos nuestra pasión por el deporte, la tecnología textil y el diseño personalizado. 
        Mantente al día con nuestras últimas novedades.
      </p>
    </section>



    {featuredPost ? (
      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-24">
        <a href={`/blog/${featuredPost.id}`} class="group block relative overflow-hidden rounded-[3rem] bg-gray-900 h-[500px] md:h-[600px] shadow-2xl">
          <img 
            src={featuredPost.data.image} 
            alt={featuredPost.data.title}
            class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:scale-105 transition-transform duration-1000"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
          
          <div class="absolute bottom-0 left-0 p-8 md:p-16 max-w-4xl">
            <span class="inline-block px-4 py-1 bg-primary text-white text-[10px] font-black uppercase tracking-widest rounded-full mb-6">
              DESTACADO • {featuredPost.data.category}
            </span>
            <h2 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight group-hover:text-primary transition-colors">
              {featuredPost.data.title}
            </h2>
            <p class="text-gray-300 text-lg font-light mb-8 line-clamp-2 md:line-clamp-none">
              {featuredPost.data.excerpt}
            </p>
            <div class="flex items-center gap-6 text-white/60 text-sm font-medium">
              <span>{formatDate(featuredPost.data.date)}</span>
              <span class="w-1 h-1 bg-white/40 rounded-full"></span>
              <span>{featuredPost.data.readTime} de lectura</span>
            </div>
          </div>
        </a>
      </section>
    ) : (
      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-24 text-center py-20 bg-gray-50 rounded-[3rem]">
        <p class="text-gray-500 text-lg">Próximamente más novedades en nuestro blog.</p>
      </section>
    )}

    {otherPosts.length > 0 && (
      <!-- Post Grid -->
      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
          {otherPosts.map((post) => (
            <article class="group">
              <a href={`/blog/${post.id}`} class="block">
                <div class="relative overflow-hidden rounded-3xl mb-6 aspect-[16/10] shadow-sm group-hover:shadow-xl transition-all duration-500">
                  <img 
                    src={post.data.image} 
                    alt={post.data.title} 
                    class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700"
                  />
                  <div class="absolute top-4 left-4">
                    <span class="px-4 py-1.5 bg-white/90 backdrop-blur-sm text-[10px] font-black text-gray-900 uppercase tracking-widest rounded-full shadow-sm">
                      {post.data.category}
                    </span>
                  </div>
                </div>
                
                <div class="space-y-4">
                  <div class="flex items-center gap-4 text-xs text-gray-400 font-medium">
                    <span>{formatDate(post.data.date)}</span>
                    <span class="w-1 h-1 bg-gray-300 rounded-full"></span>
                    <span>{post.data.readTime}</span>
                  </div>
                  
                  <h3 class="text-2xl font-bold text-gray-900 leading-snug group-hover:text-primary transition-colors duration-300">
                    {post.data.title}
                  </h3>
                  
                  <p class="text-gray-500 font-light leading-relaxed line-clamp-3">
                    {post.data.excerpt}
                  </p>
  
                  <div class="pt-2">
                    <span class="text-xs font-bold text-gray-900 flex items-center gap-2">
                      LEER ARTÍCULO 
                      <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                      </svg>
                    </span>
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- Social Media CTA -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-32">
      <div class="bg-primary rounded-[3rem] p-12 md:p-20 text-center text-white relative overflow-hidden shadow-2xl">
        <div class="absolute top-0 right-0 w-96 h-96 bg-white/10 rounded-full -mr-48 -mt-48 blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-96 h-96 bg-white/10 rounded-full -ml-48 -mb-48 blur-3xl"></div>
        
        <div class="relative z-10">
          <h2 class="text-4xl md:text-6xl font-bold mb-6 italic font-serif leading-tight">Únete a nuestra <span class="text-white underline decoration-white/30">comunidad</span></h2>
          <p class="text-xl text-white/90 font-light mb-12 max-w-2xl mx-auto leading-relaxed">
            No te pierdas nuestros procesos de fabricación, nuevos diseños y la actualidad de nuestros atletas en redes sociales.
          </p>
          
          <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
            <a 
              href="https://www.instagram.com/vessport_oficial/" 
              target="_blank" 
              class="group flex items-center gap-4 bg-white text-gray-900 px-10 py-5 rounded-2xl font-bold transition-all duration-300 hover:shadow-xl hover:-translate-y-1 w-full sm:w-auto justify-center"
            >
              <svg class="w-6 h-6 text-[#bc1888]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              INSTAGRAM
            </a>
            
            <a 
              href="https://www.facebook.com/profile.php?id=61582132148614" 
              target="_blank" 
              class="group flex items-center gap-4 bg-white text-gray-900 px-10 py-5 rounded-2xl font-bold transition-all duration-300 hover:shadow-xl hover:-translate-y-1 w-full sm:w-auto justify-center"
            >
              <svg class="w-6 h-6 text-[#1877F2]" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              FACEBOOK
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppButton />
</Layout>
